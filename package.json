{
  "name": "wifes-counselling-website",
  "version": "1.0.0",
  "description": "Relax, it's a work in progress",
  "main": "service-worker.js",
  "scripts": {
    "build-js": "terser src/main.js -o public/scripts/main.min.js --compress --mangle",
    "build-css": "sass styles/custom/scss/main.scss public/css/main.min.css --style compressed",
    "watch-css": "sass --watch styles/custom/scss/main.scss public/css/main.min.css --style compressed",
    "watch-js": "chokidar \"src/main.js\" -c \"npm run build-js\"",
    "start": "run-p watch-js watch-css",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phevenAm/wifes-counselling-website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/phevenAm/wifes-counselling-website/issues"
  },
  "homepage": "https://github.com/phevenAm/wifes-counselling-website#readme",
  "dependencies": {
    "firebase-tools": "^11.21.0"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.99.0",
    "terser": "^5.46.1"
  }
}
